<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<!-- Tab Kết quả học tập: results -->
<ScrollPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.center.manager.controllers.student.ResultsTabController"
            fitToWidth="true" style="-fx-background-color: transparent;">
    <VBox spacing="20">
        <padding><Insets top="25" bottom="25" left="30" right="30"/></padding>

        <Label text="📝 Kết quả học tập" styleClass="page-title"/>

        <VBox styleClass="dashboard-card" spacing="12">
            <TableView fx:id="tableResults" styleClass="data-table" prefHeight="300">
                <columns>
                    <TableColumn fx:id="colResClass" text="Lớp" prefWidth="160"/>
                    <TableColumn fx:id="colResCourse" text="Khóa học" prefWidth="200"/>
                    <TableColumn fx:id="colResScore" text="Điểm" prefWidth="100"/>
                    <TableColumn fx:id="colResGrade" text="Xếp loại" prefWidth="100"/>
                    <TableColumn fx:id="colResComment" text="Nhận xét" prefWidth="300"/>
                </columns>
                <placeholder><Label text="Chưa có kết quả học tập"/></placeholder>
            </TableView>
        </VBox>
    </VBox>
</ScrollPane>

