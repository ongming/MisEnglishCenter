<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<!-- Tab Lớp học: enrollment + class + course + teacher -->
<ScrollPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.center.manager.controllers.student.ClassesTabController"
            fitToWidth="true" style="-fx-background-color: transparent;">
    <VBox spacing="20">
        <padding><Insets top="25" bottom="25" left="30" right="30"/></padding>

        <Label text="📚 Lớp học đang tham gia" styleClass="page-title"/>

        <VBox styleClass="dashboard-card" spacing="12">
            <TableView fx:id="tableClasses" styleClass="data-table" prefHeight="300">
                <columns>
                    <TableColumn fx:id="colClassName" text="Tên lớp" prefWidth="140"/>
                    <TableColumn fx:id="colCourseName" text="Khóa học" prefWidth="200"/>
                    <TableColumn fx:id="colLevel" text="Trình độ" prefWidth="110"/>
                    <TableColumn fx:id="colTeacher" text="Giáo viên" prefWidth="150"/>
                    <TableColumn fx:id="colStartDate" text="Bắt đầu" prefWidth="105"/>
                    <TableColumn fx:id="colEndDate" text="Kết thúc" prefWidth="105"/>
                    <TableColumn fx:id="colStatus" text="Trạng thái" prefWidth="105"/>
                </columns>
                <placeholder><Label text="Chưa ghi danh lớp nào"/></placeholder>
            </TableView>
        </VBox>
    </VBox>
</ScrollPane>

