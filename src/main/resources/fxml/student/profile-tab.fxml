<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<!-- Tab Thông tin cá nhân -->
<ScrollPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.center.manager.controllers.student.ProfileTabController"
            fitToWidth="true" style="-fx-background-color: transparent;">
    <VBox spacing="20">
        <padding><Insets top="25" bottom="25" left="30" right="30"/></padding>

        <Label text="👤 Thông tin cá nhân" styleClass="page-title"/>

        <VBox styleClass="dashboard-card" spacing="15">
            <GridPane hgap="20" vgap="14">
                <Label text="Họ và tên:" styleClass="info-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <Label fx:id="lblFullName" text="—" styleClass="info-value" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Mã học viên:" styleClass="info-label" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                <Label fx:id="lblStudentId" text="—" styleClass="info-value" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                <Label text="Ngày sinh:" styleClass="info-label" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <Label fx:id="lblDob" text="—" styleClass="info-value" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Label text="Giới tính:" styleClass="info-label" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                <Label fx:id="lblGender" text="—" styleClass="info-value" GridPane.rowIndex="1" GridPane.columnIndex="3"/>

                <Label text="Số điện thoại:" styleClass="info-label" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <Label fx:id="lblPhone" text="—" styleClass="info-value" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                <Label text="Email:" styleClass="info-label" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
                <Label fx:id="lblEmail" text="—" styleClass="info-value" GridPane.rowIndex="2" GridPane.columnIndex="3"/>

                <Label text="Địa chỉ:" styleClass="info-label" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <Label fx:id="lblAddress" text="—" styleClass="info-value" GridPane.rowIndex="3" GridPane.columnIndex="1"
                       GridPane.columnSpan="3"/>

                <Label text="Ngày đăng ký:" styleClass="info-label" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                <Label fx:id="lblRegDate" text="—" styleClass="info-value" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

                <Label text="Trạng thái:" styleClass="info-label" GridPane.rowIndex="4" GridPane.columnIndex="2"/>
                <Label fx:id="lblStatus" text="—" styleClass="info-value" GridPane.rowIndex="4" GridPane.columnIndex="3"/>

                <columnConstraints>
                    <ColumnConstraints minWidth="120" prefWidth="130"/>
                    <ColumnConstraints minWidth="180" prefWidth="250"/>
                    <ColumnConstraints minWidth="120" prefWidth="130"/>
                    <ColumnConstraints minWidth="180" prefWidth="250"/>
                </columnConstraints>
            </GridPane>
        </VBox>

        <!-- Bài test xếp lớp -->
        <VBox styleClass="dashboard-card" spacing="12">
            <Label text="📋 Bài test xếp lớp (Placement Test)" styleClass="card-title"/>
            <Separator styleClass="form-separator"/>
            <TableView fx:id="tablePlacement" styleClass="data-table" prefHeight="120">
                <columns>
                    <TableColumn fx:id="colPtDate" text="Ngày thi" prefWidth="130"/>
                    <TableColumn fx:id="colPtScore" text="Điểm" prefWidth="100"/>
                    <TableColumn fx:id="colPtLevel" text="Trình độ gợi ý" prefWidth="160"/>
                    <TableColumn fx:id="colPtNote" text="Ghi chú" prefWidth="300"/>
                </columns>
                <placeholder><Label text="Chưa có bài test xếp lớp"/></placeholder>
            </TableView>
        </VBox>
    </VBox>
</ScrollPane>

