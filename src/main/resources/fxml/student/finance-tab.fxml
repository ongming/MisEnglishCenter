<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<!-- Tab Học phí: invoices + payments -->
<ScrollPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.center.manager.controllers.student.FinanceTabController"
            fitToWidth="true" style="-fx-background-color: transparent;">
    <VBox spacing="20">
        <padding><Insets top="25" bottom="25" left="30" right="30"/></padding>

        <Label text="💰 Học phí &amp; Thanh toán" styleClass="page-title"/>

        <!-- Hóa đơn -->
        <VBox styleClass="dashboard-card" spacing="12">
            <Label text="🧾 Hóa đơn" styleClass="card-title"/>
            <Separator styleClass="form-separator"/>
            <TableView fx:id="tableInvoices" styleClass="data-table" prefHeight="180">
                <columns>
                    <TableColumn fx:id="colInvId" text="Mã HĐ" prefWidth="80"/>
                    <TableColumn fx:id="colInvAmount" text="Số tiền" prefWidth="130"/>
                    <TableColumn fx:id="colInvDate" text="Ngày phát hành" prefWidth="130"/>
                    <TableColumn fx:id="colInvStatus" text="Trạng thái" prefWidth="110"/>
                    <TableColumn fx:id="colInvNote" text="Ghi chú" prefWidth="300"/>
                </columns>
                <placeholder><Label text="Chưa có hóa đơn"/></placeholder>
            </TableView>
        </VBox>

        <!-- Lịch sử thanh toán -->
        <VBox styleClass="dashboard-card" spacing="12">
            <Label text="💳 Lịch sử thanh toán" styleClass="card-title"/>
            <Separator styleClass="form-separator"/>
            <TableView fx:id="tablePayments" styleClass="data-table" prefHeight="200">
                <columns>
                    <TableColumn fx:id="colPayDate" text="Ngày" prefWidth="150"/>
                    <TableColumn fx:id="colPayAmount" text="Số tiền" prefWidth="130"/>
                    <TableColumn fx:id="colPayMethod" text="Phương thức" prefWidth="120"/>
                    <TableColumn fx:id="colPayStatus" text="Trạng thái" prefWidth="110"/>
                    <TableColumn fx:id="colPayRef" text="Mã tham chiếu" prefWidth="150"/>
                </columns>
                <placeholder><Label text="Chưa có giao dịch"/></placeholder>
            </TableView>
        </VBox>
    </VBox>
</ScrollPane>

