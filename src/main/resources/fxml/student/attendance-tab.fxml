<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<!-- Tab Điểm danh: attendances -->
<ScrollPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.center.manager.controllers.student.AttendanceTabController"
            fitToWidth="true" style="-fx-background-color: transparent;">
    <VBox spacing="20">
        <padding><Insets top="25" bottom="25" left="30" right="30"/></padding>

        <Label text="✅ Điểm danh" styleClass="page-title"/>

        <!-- Thống kê nhanh -->
        <HBox spacing="15">
            <VBox styleClass="stat-card" spacing="4" HBox.hgrow="ALWAYS">
                <Label fx:id="lblPresent" text="0" styleClass="stat-number" style="-fx-text-fill: #27ae60;"/>
                <Label text="Có mặt" styleClass="stat-label"/>
            </VBox>
            <VBox styleClass="stat-card" spacing="4" HBox.hgrow="ALWAYS">
                <Label fx:id="lblLate" text="0" styleClass="stat-number" style="-fx-text-fill: #f39c12;"/>
                <Label text="Đi trễ" styleClass="stat-label"/>
            </VBox>
            <VBox styleClass="stat-card" spacing="4" HBox.hgrow="ALWAYS">
                <Label fx:id="lblAbsent" text="0" styleClass="stat-number" style="-fx-text-fill: #e74c3c;"/>
                <Label text="Vắng mặt" styleClass="stat-label"/>
            </VBox>
        </HBox>

        <VBox styleClass="dashboard-card" spacing="12">
            <TableView fx:id="tableAttendance" styleClass="data-table" prefHeight="350">
                <columns>
                    <TableColumn fx:id="colAttClass" text="Lớp" prefWidth="150"/>
                    <TableColumn fx:id="colAttDate" text="Ngày" prefWidth="120"/>
                    <TableColumn fx:id="colAttStatus" text="Trạng thái" prefWidth="120"/>
                    <TableColumn fx:id="colAttNote" text="Ghi chú" prefWidth="300"/>
                </columns>
                <placeholder><Label text="Chưa có dữ liệu điểm danh"/></placeholder>
            </TableView>
        </VBox>
    </VBox>
</ScrollPane>

