<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.center.manager.controllers.LoginController"
           styleClass="login-background"
           stylesheets="@../css/styles.css"
           prefWidth="1000" prefHeight="650">

    <!-- Card đăng nhập ở giữa -->
    <VBox fx:id="loginCard" styleClass="login-card"
          alignment="CENTER" spacing="8"
          maxWidth="420" maxHeight="580">

        <!-- Logo icon -->
        <StackPane prefWidth="72" prefHeight="72"
                   style="-fx-background-color: #F5A623; -fx-background-radius: 36;">
            <Label text="🎓" style="-fx-font-size: 34px;"/>
        </StackPane>

        <Region prefHeight="5"/>

        <!-- Title -->
        <Label text="MIS English Center" styleClass="login-title"/>
        <Label text="Hệ thống quản lý trung tâm Anh ngữ" styleClass="login-subtitle"/>

        <Region prefHeight="15"/>

        <!-- Username field -->
        <VBox spacing="6" maxWidth="320">
            <Label text="Tên đăng nhập" style="-fx-font-size: 13px; -fx-text-fill: #5D4037; -fx-font-weight: bold;"/>
            <StackPane>
                <TextField fx:id="txtUsername" styleClass="text-field-modern"
                           promptText="Nhập tên đăng nhập..."
                           prefWidth="320"/>
                <Label text="👤" style="-fx-font-size: 16px; -fx-text-fill: #BDB08A;"
                       StackPane.alignment="CENTER_LEFT"
                       translateX="12"/>
            </StackPane>
        </VBox>

        <Region prefHeight="5"/>

        <!-- Password field -->
        <VBox spacing="6" maxWidth="320">
            <Label text="Mật khẩu" style="-fx-font-size: 13px; -fx-text-fill: #5D4037; -fx-font-weight: bold;"/>
            <StackPane>
                <PasswordField fx:id="txtPassword" styleClass="password-field-modern"
                               promptText="Nhập mật khẩu..."
                               prefWidth="320"/>
                <Label text="🔒" style="-fx-font-size: 16px; -fx-text-fill: #BDB08A;"
                       StackPane.alignment="CENTER_LEFT"
                       translateX="12"/>
            </StackPane>
        </VBox>

        <Region prefHeight="3"/>

        <!-- Remember me + Forgot password -->
        <HBox alignment="CENTER_LEFT" spacing="10" maxWidth="320">
            <CheckBox fx:id="chkRemember" text="Ghi nhớ đăng nhập"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Hyperlink fx:id="linkForgot" text="Quên mật khẩu?" styleClass="forgot-link"/>
        </HBox>

        <!-- Error message -->
        <Label fx:id="lblError" styleClass="error-label" maxWidth="320"
               wrapText="true" alignment="CENTER"/>

        <Region prefHeight="8"/>

        <!-- Login button -->
        <Button fx:id="btnLogin" text="ĐĂNG NHẬP" styleClass="login-btn"
                prefWidth="320" onAction="#handleLogin"/>

        <!-- Loading indicator (ẩn mặc định) -->
        <ProgressIndicator fx:id="loadingSpinner" prefWidth="30" prefHeight="30"
                           visible="false" style="-fx-progress-color: #F5A623;"/>

        <Region prefHeight="10"/>

        <!-- Separator -->
        <HBox alignment="CENTER" spacing="10" maxWidth="320">
            <Separator HBox.hgrow="ALWAYS"/>
            <Label text="hoặc" style="-fx-text-fill: #adb5bd; -fx-font-size: 12px;"/>
            <Separator HBox.hgrow="ALWAYS"/>
        </HBox>

        <Region prefHeight="5"/>

        <!-- Footer -->
        <Label text="Liên hệ quản trị viên để được cấp tài khoản"
               style="-fx-text-fill: #adb5bd; -fx-font-size: 12px;"/>
    </VBox>

    <!-- Version ở góc dưới -->
    <Label text="v1.0.0 © 2026 MIS English Center" styleClass="version-text"
           StackPane.alignment="BOTTOM_CENTER"
           translateY="-15"/>

</StackPane>



