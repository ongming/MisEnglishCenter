<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<!-- Giao diện Dashboard cho Giảng viên (Teacher) -->
<!-- Cấu trúc giống Student Dashboard: Sidebar bên trái + Content bên phải -->
<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.center.manager.controllers.TeacherDashboardController"
            stylesheets="@../css/styles.css"
            styleClass="main-background"
            prefWidth="1200" prefHeight="750">

    <!-- ============ LEFT: Sidebar ============ -->
    <left>
        <VBox styleClass="sidebar" prefWidth="230" spacing="0">

            <!-- Avatar + Tên -->
            <VBox alignment="CENTER" spacing="5" styleClass="sidebar-profile">
                <padding><Insets top="20" bottom="15" left="15" right="15"/></padding>
                <Label text="👨‍🏫" style="-fx-font-size: 40px;"/>
                <Label fx:id="lblSidebarName" text="Giảng viên" styleClass="sidebar-name"/>
                <Label fx:id="lblSidebarRole" text="Teacher" styleClass="sidebar-role-badge"/>
            </VBox>

            <Separator style="-fx-background-color: rgba(255,255,255,0.2);"/>

            <!-- Navigation — Giảng viên chỉ cần vài mục -->
            <VBox spacing="2" styleClass="sidebar-nav">
                <padding><Insets top="10" bottom="10" left="8" right="8"/></padding>

                <Button fx:id="btnMyClasses" text="📚  Lớp đang dạy" styleClass="sidebar-btn"
                        onAction="#handleMyClassesTab" maxWidth="Infinity"/>
                <Button fx:id="btnSchedule" text="📅  Lịch dạy" styleClass="sidebar-btn"
                        onAction="#handleScheduleTab" maxWidth="Infinity"/>
                <Button fx:id="btnAttendance" text="✅  Điểm danh" styleClass="sidebar-btn"
                        onAction="#handleAttendanceTab" maxWidth="Infinity"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <!-- Logout -->
            <VBox styleClass="sidebar-bottom">
                <padding><Insets top="10" bottom="15" left="8" right="8"/></padding>
                <Button text="🚪  Đăng xuất" styleClass="sidebar-btn-logout"
                        onAction="#handleLogout" maxWidth="Infinity"/>
            </VBox>
        </VBox>
    </left>

    <!-- ============ CENTER: Content Area ============ -->
    <center>
        <StackPane fx:id="contentArea" styleClass="main-background">
            <padding><Insets top="0" bottom="0" left="0" right="0"/></padding>
        </StackPane>
    </center>

</BorderPane>

